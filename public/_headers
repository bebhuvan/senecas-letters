# Hashed build assets — immutable, cache forever
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts (if ever self-hosted) — immutable
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# JSON data files — long cache, revalidate daily
/enhanced-index.json
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800

/og-default.png
  Cache-Control: public, max-age=86400, s-maxage=604800, immutable

# Sitemap + robots — short cache
/sitemap.xml
  Cache-Control: public, max-age=3600, s-maxage=86400
/robots.txt
  Cache-Control: public, max-age=3600, s-maxage=86400

# Every HTML page — short browser cache, long CDN cache, revalidate in background
/*
  Cache-Control: public, max-age=0, s-maxage=300, stale-while-revalidate=86400
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
