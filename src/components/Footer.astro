---
---

<footer class="footer">
  <div class="container">
    <figure class="footer__quote">
      <blockquote class="footer__quote-text">
        Omnia aliena sunt, tempus tantum nostrum.
      </blockquote>
      <figcaption class="footer__quote-attr">All things are foreign; time alone is ours — Letter I</figcaption>
    </figure>

    <div class="footer__inner">
      <span class="footer__copy">Public domain · Wikisource</span>
      <div class="footer__links">
        <a href="/about">About</a>
        <a href="https://en.wikisource.org/wiki/Moral_letters_to_Lucilius" target="_blank" rel="noopener">Source</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-light);
    margin-top: var(--space-24);
    padding-bottom: var(--space-8);
  }

  .footer__quote {
    text-align: center;
    padding: var(--space-12) 0 var(--space-10);
    margin-bottom: var(--space-6);
    border-bottom: 1px solid var(--border-light);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    position: relative;
  }

  .footer__quote::before {
    content: '\201C';
    font-family: var(--font-display);
    font-size: 5rem;
    font-weight: 300;
    color: var(--color-accent);
    opacity: 0.18;
    position: absolute;
    top: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    line-height: 1;
    pointer-events: none;
  }

  :global([data-theme="dark"]) .footer__quote::before {
    opacity: 0.22;
  }

  .footer__quote-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.5;
    letter-spacing: -0.01em;
  }

  .footer__quote-attr {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.06em;
    margin-top: var(--space-4);
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 0 var(--space-2);
  }

  .footer__copy {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }

  .footer__links {
    display: flex;
    gap: var(--space-6);
  }

  .footer__links a {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.03em;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .footer__links a:hover {
    color: var(--text-primary);
  }

  @media (max-width: 480px) {
    .footer__inner {
      flex-direction: column;
      gap: var(--space-3);
    }
  }
</style>
