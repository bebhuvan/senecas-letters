---
export interface Props {
  letterNumber: string;
  title: string;
  excerpt: string;
  readingTime: number;
  date?: string;
  featured?: boolean;
  href: string;
}

const { letterNumber, title, excerpt, readingTime, date, featured = false, href } = Astro.props;
---

<a href={href} class:list={["letter-card", { featured }]}>
  <div class="letter-number">{letterNumber}</div>
  <h3 class="letter-title">{title}</h3>
  <p class="letter-excerpt">{excerpt}</p>
  <div class="letter-meta-info">
    {date && <span>{date}</span>}
    <span>{readingTime} min read</span>
  </div>
</a>

<style>
  .letter-card {
    padding: 2.25rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, border-color 0.2s ease;
    display: flex;
    flex-direction: column;
  }
  
  .letter-card:hover {
    transform: translateY(-2px);
    border-color: var(--royal-blue);
  }
  
  .letter-card.featured {
    grid-column: span 2;
    grid-row: span 2;
    background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-soft) 100%);
  }
  
  .letter-number {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--royal-blue);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }
  
  .letter-title {
    font-size: var(--text-xl);
    font-weight: 400;
    margin-bottom: 1.25rem;
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
  }
  
  .letter-card.featured .letter-title {
    font-size: var(--text-2xl);
  }
  
  .letter-excerpt {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    flex-grow: 1;
    margin-bottom: 2rem;
    letter-spacing: var(--tracking-normal);
  }
  
  .letter-card.featured .letter-excerpt {
    font-size: var(--text-md);
    line-height: var(--leading-loose);
  }
  
  .letter-meta-info {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-tertiary);
    display: flex;
    justify-content: space-between;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border-light);
    letter-spacing: var(--tracking-wide);
  }
  
  @media (max-width: 768px) {
    .letter-card.featured {
      grid-column: span 1;
      grid-row: span 1;
    }
  }
</style>