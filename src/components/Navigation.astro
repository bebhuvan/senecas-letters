---
const currentPath = Astro.url.pathname;
---

<div class="nav-container">
  <nav>
    <a href="/" class="logo">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="logo-icon">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M6.5 2H20v20l-5.5-6-5.5 6V2Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
      </svg>
      <span class="logo-text">Seneca</span>
    </a>
    <div class="nav-items">
      <a href="/archive" class:list={["nav-link", { active: currentPath === '/archive' }]}>Archive</a>
      <a href="/about" class:list={["nav-link", { active: currentPath === '/about' }]}>About</a>
      <a href="/search" class:list={["nav-link", { active: currentPath === '/search' }]}>Search</a>
      <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z">
          </path>
        </svg>
      </button>
    </div>
  </nav>
</div>

<style>
  .nav-container {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    padding: 1.25rem 2rem;
    backdrop-filter: blur(10px);
    background: rgba(255, 255, 255, 0.98);
    z-index: 100;
    border-bottom: 1px solid var(--border-light);
    transition: background-color 0.3s ease;
  }
  
  :global([data-theme="dark"]) .nav-container {
    background: rgba(10, 10, 10, 0.98) !important;
  }
  
  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-md);
    font-weight: 500;
    letter-spacing: var(--tracking-tight);
    text-decoration: none;
    color: var(--text-primary);
  }
  
  .logo-icon {
    width: 20px;
    height: 20px;
    color: var(--royal-blue);
    opacity: 0.8;
  }
  
  .logo-text {
    font-family: var(--font-serif);
  }
  
  .nav-items {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
  }
  
  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
    letter-spacing: var(--tracking-wide);
  }
  
  .nav-link:hover,
  .nav-link.active {
    color: var(--text-primary);
  }
  
  .theme-toggle {
    width: 20px;
    height: 20px;
    cursor: pointer;
    color: var(--text-secondary);
    transition: color 0.2s ease;
    background: none;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  
  .theme-toggle:hover {
    color: var(--text-primary);
  }
  
  .theme-toggle svg {
    width: 100%;
    height: 100%;
  }
  
  /* Mobile Navigation */
  @media (max-width: 768px) {
    .nav-items {
      gap: 1rem;
      font-size: var(--text-sm);
    }
    
    .nav-link {
      letter-spacing: normal;
    }
  }
  
  @media (max-width: 480px) {
    .nav-container {
      padding: 1rem 1.5rem;
    }
    
    .nav-items {
      gap: 0.75rem;
    }
    
    .nav-link {
      font-size: var(--text-xs);
    }
  }
</style>