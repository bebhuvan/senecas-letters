---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Library — Letters to Lucilius">
  <Header currentPath="/library" />

  <main>
    <section class="library">
      <div class="container">

        <!-- Header -->
        <div class="library__head">
          <div class="library__head-text">
            <h1 class="library__title">Library</h1>
            <p class="library__subtitle">124 letters on virtue, mortality, and the art of living</p>
          </div>

          <div class="library__search">
            <input
              type="text"
              id="searchInput"
              class="library__search-input"
              placeholder="Search letters, themes, ideas…"
              autocomplete="off"
            />
            <span class="library__search-hint">Press <kbd>/</kbd> to focus</span>
          </div>
        </div>

        <!-- Toolbar -->
        <div class="library__toolbar">
          <div class="library__filters" id="filterPills">
            <button class="library__pill active" data-filter="">All</button>
            <button class="library__pill" data-filter="short">Brief</button>
            <button class="library__pill" data-filter="medium">Standard</button>
            <button class="library__pill" data-filter="long">Deep</button>
          </div>

          <div class="library__toolbar-right">
            <button class="library__random" id="randomLetterBtn" title="Open a random letter">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12h4l6-8h4M11 4l4 0 0 4M11 12l4 0 0-4"/></svg>
              Random
            </button>
            <div id="resultCount" class="library__count"></div>
            <div class="library__view-toggle">
              <button class="library__view-btn active" data-view="list" aria-label="List view" title="List view">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                  <line x1="0" y1="3.5" x2="16" y2="3.5"/>
                  <line x1="0" y1="8" x2="16" y2="8"/>
                  <line x1="0" y1="12.5" x2="16" y2="12.5"/>
                </svg>
              </button>
              <button class="library__view-btn" data-view="collections" aria-label="Collections view" title="Collections view">
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="1" y="1" width="5.5" height="5.5" rx="0.75"/>
                  <rect x="9.5" y="1" width="5.5" height="5.5" rx="0.75"/>
                  <rect x="1" y="9.5" width="5.5" height="5.5" rx="0.75"/>
                  <rect x="9.5" y="9.5" width="5.5" height="5.5" rx="0.75"/>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Letter list view -->
        <div class="library__list" id="lettersList">
          <div class="library__loading">Loading letters…</div>
        </div>

        <!-- Collections view -->
        <div class="library__collections" id="collectionsView" style="display:none;"></div>

        <!-- Empty state -->
        <div class="library__empty" id="emptyState" style="display:none;">
          <p class="library__empty-text">No letters found</p>
          <p class="library__empty-hint">Try different terms or clear your filters</p>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .library {
    padding: var(--space-12) 0 var(--space-24);
    background: var(--bg-primary);
  }

  /* ── Header ── */
  .library__head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--border-primary);
  }

  .library__title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 8vw, 5.5rem);
    font-weight: 300;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .library__subtitle {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .library__search {
    position: relative;
    width: 100%;
    max-width: 460px;
  }

  .library__search-input {
    width: 100%;
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-primary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-sm);
    outline: none;
    transition: border-color var(--duration-fast) ease, background var(--duration-fast) ease;
  }

  .library__search-input::placeholder {
    color: var(--text-muted);
  }

  .library__search-input:focus {
    border-color: var(--text-secondary);
    background: var(--bg-primary);
  }

  .library__search-input:focus ~ .library__search-hint {
    display: none;
  }

  .library__search-hint {
    position: absolute;
    right: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .library__search-hint kbd {
    font-family: var(--font-sans);
    font-size: 0.625rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-primary);
    border-radius: 3px;
    padding: 1px 5px;
    color: var(--text-muted);
  }

  /* ── Toolbar ── */
  .library__toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
  }

  .library__filters {
    display: flex;
    gap: 0;
  }

  .library__pill {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--text-muted);
    background: none;
    border: none;
    padding: var(--space-1) var(--space-4);
    border-bottom: 1.5px solid transparent;
    transition: color var(--duration-fast) ease, border-color var(--duration-fast) ease;
  }

  .library__pill:first-child {
    padding-left: 0;
  }

  .library__pill:hover {
    color: var(--text-secondary);
  }

  .library__pill.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .library__random {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    background: none;
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3);
    display: flex;
    align-items: center;
    gap: 5px;
    transition: color var(--duration-fast) ease, border-color var(--duration-fast) ease;
  }

  .library__random:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .library__toolbar-right {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .library__count {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }

  .library__view-toggle {
    display: flex;
    gap: 2px;
  }

  .library__view-btn {
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid transparent;
    border-radius: 3px;
    color: var(--text-muted);
    transition: color var(--duration-fast) ease, border-color var(--duration-fast) ease;
  }

  .library__view-btn:hover {
    color: var(--text-secondary);
  }

  .library__view-btn.active {
    color: var(--text-primary);
    border-color: var(--border-primary);
  }

  /* ── Letter list ── */
  .library__list {
    border-top: 1px solid var(--border-primary);
  }

  .library__loading {
    text-align: center;
    padding: var(--space-16);
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
  }

  /* ── Empty state ── */
  .library__empty {
    text-align: center;
    padding: var(--space-20) 0;
  }

  .library__empty-text {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-style: italic;
    font-weight: 300;
    color: var(--text-secondary);
    margin-bottom: var(--space-2);
  }

  .library__empty-hint {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }

  /* ── JS-generated letter rows ── */
  :global(.library__row) {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    align-items: start;
    gap: var(--space-6);
    padding: var(--space-5) 0;
    padding-left: var(--space-3);
    border-bottom: 1px solid var(--border-light);
    text-decoration: none;
    transition: background var(--duration-fast) ease;
  }

  :global(.library__row:hover) {
    background: var(--color-accent-subtle);
  }

  :global(.library__row-number) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1;
    letter-spacing: -0.01em;
    transition: color var(--duration-fast) ease;
  }

  :global(.library__row:hover .library__row-number) {
    color: var(--color-accent);
  }

  :global(.library__row-center) {
    min-width: 0;
  }

  :global(.library__row-title) {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--text-primary);
    display: block;
    line-height: 1.3;
    letter-spacing: -0.01em;
    transition: color var(--duration-fast) ease;
  }

  :global(.library__row:hover .library__row-title) {
    color: var(--color-accent);
  }

  :global(.library__row-theme) {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    display: block;
    margin-top: 3px;
    letter-spacing: 0.01em;
  }

  :global(.library__row-preview) {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--text-muted);
    display: block;
    margin-top: var(--space-1);
    line-height: 1.5;
  }

  :global(.library__row-meta) {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  :global(.library__row-time) {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    white-space: nowrap;
  }

  /* ── Collections view ── */
  .library__collections {
    border-top: 1px solid var(--border-primary);
  }

  :global(.collection-section) {
    padding: var(--space-8) 0 var(--space-8) var(--space-5);
    border-bottom: 1px solid var(--border-light);
    border-left: 2px solid var(--border-primary);
    transition: background var(--duration-normal) ease, border-color var(--duration-normal) ease;
  }

  :global(.collection-section--highlight) {
    background: var(--color-accent-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-4) var(--space-8);
    margin: 0 calc(-1 * var(--space-4));
    border-left-color: var(--color-accent);
  }

  :global(.collection-section__header) {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  :global(.collection-section__name) {
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 400;
    font-style: italic;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  :global(.collection-section__count) {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }

  :global(.collection-section__desc) {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-5);
    letter-spacing: 0.01em;
  }

  :global(.collection-section__letters) {
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 768px) {
    .library {
      padding: var(--space-8) 0 var(--space-16);
    }

    :global(.library__row) {
      grid-template-columns: 3rem 1fr;
      gap: var(--space-3);
      padding-left: var(--space-2);
    }

    :global(.library__row-meta) {
      display: none;
    }

    .library__view-toggle {
      display: none;
    }
  }
</style>

<script is:inline>
(function() {
  var enhancedIndex = null;
  var searchPhrase = '';
  var searchTokens = [];
  var currentFilter = '';
  var currentView = 'list';

  var STOP_WORDS_SET = {};
  ['the','and','for','with','from','that','this','your','have','will','are','was','were','his','her','their','you','but','not','our','all'].forEach(function(w) {
    STOP_WORDS_SET[w] = true;
  });

  function tokenizeSearch(value) {
    return value
      .toLowerCase()
      .split(/[\s,]+/)
      .map(function(token) { return token.replace(/^[^a-z0-9]+|[^a-z0-9]+$/g, ''); })
      .filter(function(token) { return token.length > 0 && !STOP_WORDS_SET[token]; });
  }

  function scoreLetter(letter) {
    if (!searchPhrase) return 0;
    var haystack = [
      letter.t, letter.th, letter.p || '',
      letter.timeline ? letter.timeline.year + ' ' + letter.timeline.season : ''
    ].join(' ').toLowerCase();

    var phraseMatch = haystack.includes(searchPhrase);
    var score = phraseMatch ? 60 : 0;
    var matched = phraseMatch;
    var tokensToCheck = searchTokens.length > 0 ? searchTokens : searchPhrase.split(/\s+/).filter(Boolean);

    tokensToCheck.forEach(function(token) {
      if (!token) return;
      if (letter.n && (letter.n.toString() === token || letter.n.toString() === searchPhrase)) {
        score += 100; matched = true; return;
      }
      if (haystack.includes(token)) { score += 25; matched = true; }
      if (letter.k && letter.k.some(function(keyword) { return keyword.includes(token); })) {
        score += 20; matched = true;
      }
    });
    return matched ? score : -1;
  }

  function loadEnhancedIndex() {
    if (enhancedIndex) return Promise.resolve(enhancedIndex);
    return fetch('/api/enhanced-index.json')
      .then(function(r) { return r.json(); })
      .then(function(data) { enhancedIndex = data; return data; })
      .catch(function(e) { console.error('[Library] Failed to load index:', e); return null; });
  }

  function toTitleCase(str) {
    return str.toLowerCase().replace(/\b\w/g, function(l) { return l.toUpperCase(); });
  }

  function createSlug(title) {
    return title.toLowerCase()
      .replace(/[^a-z0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .trim();
  }

  function readingTime(wc) {
    return Math.ceil(wc / 220) + ' min';
  }

  function createRowElement(letter) {
    var cleanTitle = toTitleCase(letter.t.replace(/\[\d+\]/g, '').trim());
    var slug = createSlug(cleanTitle);
    var url = '/letters/' + letter.n + '-' + slug;
    var wc = letter.meta ? letter.meta.wordCount : 0;

    var a = document.createElement('a');
    a.href = url;
    a.className = 'library__row';

    var numSpan = document.createElement('span');
    numSpan.className = 'library__row-number';
    numSpan.textContent = String(letter.n);

    var centerDiv = document.createElement('div');
    centerDiv.className = 'library__row-center';

    var titleSpan = document.createElement('span');
    titleSpan.className = 'library__row-title';
    titleSpan.textContent = cleanTitle;

    var themeSpan = document.createElement('span');
    themeSpan.className = 'library__row-theme';
    themeSpan.textContent = letter.th;

    centerDiv.appendChild(titleSpan);
    centerDiv.appendChild(themeSpan);

    if (letter.p) {
      var rawPreview = letter.p.replace(/^\d+\.\s+/, '').replace(/\[\d+\]/g, '').trim();
      var preview = rawPreview.length > 120 ? rawPreview.substring(0, 120) + '…' : rawPreview;
      var previewSpan = document.createElement('span');
      previewSpan.className = 'library__row-preview';
      previewSpan.textContent = preview;
      centerDiv.appendChild(previewSpan);
    }

    var metaDiv = document.createElement('div');
    metaDiv.className = 'library__row-meta';

    if (wc) {
      var timeSpan = document.createElement('span');
      timeSpan.className = 'library__row-time';
      timeSpan.textContent = readingTime(wc);
      metaDiv.appendChild(timeSpan);
    }

    a.appendChild(numSpan);
    a.appendChild(centerDiv);
    a.appendChild(metaDiv);
    return a;
  }

  function filterLetters(letters) {
    return letters.filter(function(letter) {
      if (searchPhrase) {
        var score = scoreLetter(letter);
        if (score <= 0) return false;
        letter._score = score;
      } else {
        letter._score = 0;
      }
      if (currentFilter && letter.meta && letter.meta.length !== currentFilter) return false;
      if (currentFilter && !letter.meta) return false;
      return true;
    });
  }

  function renderList() {
    var index = enhancedIndex;
    if (!index) return;

    var container = document.getElementById('lettersList');
    var countDiv = document.getElementById('resultCount');
    var emptyState = document.getElementById('emptyState');
    if (!container) return;

    var filtered = filterLetters(index.letters.slice());
    if (searchPhrase) {
      filtered.sort(function(a, b) { return (b._score || 0) - (a._score || 0); });
    }

    while (container.firstChild) container.removeChild(container.firstChild);

    if (filtered.length === 0) {
      container.style.display = 'none';
      if (emptyState) emptyState.style.display = 'block';
    } else {
      container.style.display = 'block';
      if (emptyState) emptyState.style.display = 'none';
      var fragment = document.createDocumentFragment();
      filtered.forEach(function(l) { fragment.appendChild(createRowElement(l)); });
      container.appendChild(fragment);
    }

    if (countDiv) {
      countDiv.textContent = (searchPhrase || currentFilter)
        ? filtered.length + ' letter' + (filtered.length !== 1 ? 's' : '')
        : '';
    }
  }

  function renderCollections() {
    var index = enhancedIndex;
    if (!index) return;

    var container = document.getElementById('collectionsView');
    if (!container) return;
    while (container.firstChild) container.removeChild(container.firstChild);

    var fragment = document.createDocumentFragment();
    Object.keys(index.collections).forEach(function(name) {
      var collection = index.collections[name];
      var section = document.createElement('div');
      section.className = 'collection-section';
      section.setAttribute('data-collection', name);

      var header = document.createElement('div');
      header.className = 'collection-section__header';

      var nameEl = document.createElement('h3');
      nameEl.className = 'collection-section__name';
      nameEl.textContent = name;

      var countBadge = document.createElement('span');
      countBadge.className = 'collection-section__count';
      countBadge.textContent = collection.letters.length + ' letters';

      header.appendChild(nameEl);
      header.appendChild(countBadge);

      var desc = document.createElement('p');
      desc.className = 'collection-section__desc';
      desc.textContent = collection.description;

      var lettersList = document.createElement('div');
      lettersList.className = 'collection-section__letters';

      collection.letters.forEach(function(letterNum) {
        var letter = index.letters.find(function(l) { return l.n === letterNum; });
        if (letter) lettersList.appendChild(createRowElement(letter));
      });

      section.appendChild(header);
      section.appendChild(desc);
      section.appendChild(lettersList);
      fragment.appendChild(section);
    });

    container.appendChild(fragment);
  }

  function render() {
    if (!enhancedIndex) return;
    var listView = document.getElementById('lettersList');
    var collectionsViewEl = document.getElementById('collectionsView');

    if (currentView === 'list') {
      if (listView) listView.style.display = 'block';
      if (collectionsViewEl) collectionsViewEl.style.display = 'none';
      renderList();
    } else {
      if (listView) listView.style.display = 'none';
      if (collectionsViewEl) collectionsViewEl.style.display = 'block';
      var emptyState = document.getElementById('emptyState');
      if (emptyState) emptyState.style.display = 'none';
      renderCollections();
    }
  }

  function setView(view) {
    currentView = view;
    document.querySelectorAll('.library__view-btn').forEach(function(btn) {
      btn.classList.toggle('active', btn.getAttribute('data-view') === view);
    });
    render();
  }

  function handleURLParams() {
    var params = new URLSearchParams(window.location.search);
    var collection = params.get('collection');
    var period = params.get('period');

    if (collection) {
      setView('collections');
      setTimeout(function() {
        var sections = document.querySelectorAll('.collection-section');
        sections.forEach(function(section) {
          if (section.getAttribute('data-collection') === collection) {
            section.scrollIntoView({ behavior: 'smooth', block: 'start' });
            section.classList.add('collection-section--highlight');
          }
        });
      }, 100);
    }

    if (period) {
      loadEnhancedIndex().then(function(index) {
        if (!index) return;
        var timelinePeriod = index.timeline.find(function(t) { return t.season === period; });
        if (!timelinePeriod) return;
        var letterNums = {};
        timelinePeriod.letters.forEach(function(n) { letterNums[n] = true; });

        var container = document.getElementById('lettersList');
        var countDiv = document.getElementById('resultCount');
        if (!container) return;
        while (container.firstChild) container.removeChild(container.firstChild);

        var fragment = document.createDocumentFragment();
        var count = 0;
        index.letters.forEach(function(l) {
          if (letterNums[l.n]) { fragment.appendChild(createRowElement(l)); count++; }
        });
        container.appendChild(fragment);

        if (countDiv) {
          countDiv.textContent = timelinePeriod.year + ' · ' + timelinePeriod.season + ' — ' + count + ' letters';
        }
      });
    }
  }

  function debounce(func, wait) {
    var timeout;
    return function() {
      var args = arguments; var context = this;
      clearTimeout(timeout);
      timeout = setTimeout(function() { func.apply(context, args); }, wait);
    };
  }

  function init() {
    var searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('input', debounce(function() {
        searchPhrase = searchInput.value.trim().toLowerCase();
        searchTokens = tokenizeSearch(searchInput.value);
        if (currentView === 'collections' && searchPhrase) setView('list');
        render();
      }, 280));
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === '/' && document.activeElement !== searchInput) {
        e.preventDefault();
        if (searchInput) searchInput.focus();
      }
      if (e.key === 'Escape' && document.activeElement === searchInput) {
        searchInput.blur();
      }
    });

    document.querySelectorAll('.library__pill').forEach(function(pill) {
      pill.addEventListener('click', function() {
        document.querySelectorAll('.library__pill').forEach(function(p) { p.classList.remove('active'); });
        this.classList.add('active');
        currentFilter = this.dataset.filter;
        render();
      });
    });

    document.querySelectorAll('.library__view-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        setView(this.getAttribute('data-view'));
      });
    });

    var randomBtn = document.getElementById('randomLetterBtn');
    if (randomBtn) {
      randomBtn.addEventListener('click', function() {
        loadEnhancedIndex().then(function(index) {
          if (!index || !index.letters.length) return;
          var letter = index.letters[Math.floor(Math.random() * index.letters.length)];
          var cleanTitle = toTitleCase(letter.t.replace(/\[\d+\]/g, '').trim());
          window.location.href = '/letters/' + letter.n + '-' + createSlug(cleanTitle);
        });
      });
    }

    loadEnhancedIndex().then(function() {
      render();
      handleURLParams();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
