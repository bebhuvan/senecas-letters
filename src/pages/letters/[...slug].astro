---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { createSlug } from '../../utils/slugs';

export async function getStaticPaths() {
  const letters = await getCollection('letters');
  
  return letters.map((letter) => ({
    params: { slug: createSlug(letter.data.title, letter.data.number) },
    props: { letter }
  }));
}

type Props = {
  letter: CollectionEntry<'letters'>;
};

const { letter } = Astro.props;
const { Content } = await letter.render();

// Enhanced SEO meta description
const seoDescription = `Read Seneca's Letter ${letter.data.number}: ${letter.data.title}. Ancient Stoic wisdom on ${letter.data.themes.join(', ')} for modern life. Free complete text with commentary. ${letter.data.readingTime} min read.`;

// Structured data for SEO
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `Letter ${letter.data.number}: ${letter.data.title}`,
  "description": seoDescription,
  "author": {
    "@type": "Person",
    "name": "Lucius Annaeus Seneca"
  },
  "datePublished": "62-65 CE",
  "dateModified": new Date().toISOString(),
  "publisher": {
    "@type": "Organization",
    "name": "Seneca's Letters to Lucilius",
    "url": Astro.site?.toString()
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": new URL(Astro.url.pathname, Astro.site).toString()
  },
  "keywords": letter.data.themes.join(", "),
  "genre": "Philosophy",
  "inLanguage": "en-US",
  "wordCount": letter.data.readingTime * 250, // Approx words per minute
  "timeRequired": `PT${letter.data.readingTime}M`
};

// Get minimal data for navigation - only fetch what we need
const allLetters = await getCollection('letters');
const letterNumbers = allLetters.map(l => ({ number: l.data.number, title: l.data.title, themes: l.data.themes })).sort((a, b) => a.number - b.number);
const currentIndex = letterNumbers.findIndex(l => l.number === letter.data.number);
const prevLetter = currentIndex > 0 ? letterNumbers[currentIndex - 1] : null;
const nextLetter = currentIndex < letterNumbers.length - 1 ? letterNumbers[currentIndex + 1] : null;

// Find related letters by shared themes - limit processing
const relatedLetters = allLetters
  .filter(l => l.data.number !== letter.data.number && 
         l.data.themes.some(theme => letter.data.themes.includes(theme)))
  .slice(0, 3)
---

<BaseLayout 
  title={`Letter ${letter.data.number}: ${letter.data.title} - Seneca's Letters to Lucilius`}
  description={seoDescription}
  structuredData={structuredData}
>
  <!-- Progress Bar -->
  <div class="progress-container">
    <div class="progress-bar" id="progressBar"></div>
  </div>
  
  <!-- Header -->
  <header class="article-header" id="header">
    <div class="header-content">
      <div class="nav-left">
        <a href="/archive" class="back-button">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Archive
        </a>
        <span class="letter-nav-indicator">Letter {letter.data.number} of 124</span>
      </div>
      
      <div class="header-actions">
        <div class="reading-controls">
          <select class="font-selector" onchange="changeFont(this.value)">
            <option value="serif">Georgia</option>
            <option value="georgia">Georgia Pro</option>
            <option value="sans">Sans</option>
            <option value="system">System</option>
            <option value="mono">Mono</option>
          </select>
          <div class="font-size-control">
            <button class="font-size-btn" onclick="changeFontSize('decrease')">A-</button>
            <button class="font-size-btn" onclick="changeFontSize('reset')">A</button>
            <button class="font-size-btn" onclick="changeFontSize('increase')">A+</button>
          </div>
          <span class="reading-time">{letter.data.readingTime} min</span>
        </div>
        <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                  d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z">
            </path>
          </svg>
        </button>
      </div>
    </div>
  </header>
  
  <!-- Article -->
  <article>
    <div class="article-container">
      <Breadcrumb items={[
        { label: "Home", href: "/" },
        { label: "Letters", href: "/archive" },
        { label: `Letter ${letter.data.number}` }
      ]} />
      
      <div class="letter-title-section">
        <div class="letter-label">Letter {letter.data.number}</div>
        <h1 class="letter-title">{letter.data.title}</h1>
        <div class="letter-meta">
          <span class="meta-item">To Lucilius Junior</span>
          <span class="meta-item">{letter.data.location || 'Rome'}</span>
          <span class="meta-item">{letter.data.date}</span>
        </div>
      </div>
      
      <div class="letter-content">
        <Content />
      </div>
      
      <!-- Related Letters for Internal Linking -->
      {relatedLetters.length > 0 && (
        <section class="related-letters">
          <h2>Related Letters</h2>
          <p>Explore similar themes in Seneca's other writings:</p>
          <div class="related-grid">
            {relatedLetters.map(related => (
              <a href={`/letters/${createSlug(related.data.title, related.data.number)}`} class="related-card">
                <div class="related-number">Letter {related.data.number}</div>
                <div class="related-title">{related.data.title}</div>
                <div class="related-themes">
                  {related.data.themes.filter(t => letter.data.themes.includes(t)).join(', ')}
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
    
    <!-- Navigation -->
    {(prevLetter || nextLetter) && (
      <nav class="letter-navigation">
        {prevLetter && (
          <a href={`/letters/${createSlug(prevLetter.title, prevLetter.number)}`} class="nav-card">
            <div class="nav-direction">Previous</div>
            <div class="nav-title">{prevLetter.title}</div>
            <div class="nav-number">Letter {prevLetter.number}</div>
          </a>
        )}
        {nextLetter && (
          <a href={`/letters/${createSlug(nextLetter.title, nextLetter.number)}`} class="nav-card next">
            <div class="nav-direction">Next</div>
            <div class="nav-title">{nextLetter.title}</div>
            <div class="nav-number">Letter {nextLetter.number}</div>
          </a>
        )}
      </nav>
    )}
  </article>
  
  <script src="/letter.js" defer></script>
</BaseLayout>

<style>
  /* These styles need to be inline due to :global() selectors */
  
  /* Font Family Classes */
  :global(.font-serif) .letter-content :global(p) {
    font-family: var(--font-serif);
  }
  
  :global(.font-georgia) .letter-content :global(p) {
    font-family: Georgia, 'Times New Roman', serif;
  }
  
  :global(.font-sans) .letter-content :global(p) {
    font-family: var(--font-sans);
  }
  
  :global(.font-system) .letter-content :global(p) {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
  }
  
  :global(.font-mono) .letter-content :global(p) {
    font-family: 'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', monospace;
    font-size: 0.95em;
  }
  
  /* Reading Mode Classes */
  :global(.reading-mode-compact) .letter-content :global(p) {
    font-size: 1.2rem;
    line-height: 1.65;
    margin-bottom: 1.875rem;
  }
  
  :global(.reading-mode-comfort) .letter-content :global(p) {
    font-size: 1.3rem;
    line-height: 1.7;
    margin-bottom: 2.25rem;
  }
  
  :global(.reading-mode-spacious) .letter-content :global(p) {
    font-size: 1.45rem;
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }
</style>