---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import lettersData from '../data/all_letters.json';
import enhancedIndexRaw from '../../public/enhanced-index.json';
import { createSlug, cleanTitle, titleCase, getLetterUrl, readingTime, toRoman } from '../utils/text';

const enhancedIndex = enhancedIndexRaw as {
  letters: Array<{
    n: number; t: string; p: string; th: string;
    k: string[]; meta: { length: string; difficulty: string; wordCount: number };
    collections: string[]; timeline: { year: string; season: string } | null;
  }>;
  collections: Record<string, { letters: number[]; description: string; difficulty: string }>;
  timeline: Array<{ year: string; season: string; letters: number[] }>;
};

// Stats
const totalWords = enhancedIndex.letters.reduce((s, l) => s + l.meta.wordCount, 0);

// Letter I preview — combine greeting + first substantive paragraph
const letterOne = lettersData.letters.find(l => l.number === 1);
const letterOneOpening = (() => {
  if (!letterOne) return '';
  const paragraphs = letterOne.content
    .split('\n\n')
    .map(p => p.replace(/^\d+\.\s+/, '').replace(/\[\d+\]/g, '').replace(/\n/g, ' ').trim())
    .filter(p => p.length > 0);
  const greeting = paragraphs[0] ?? '';
  const body = paragraphs[1] ?? '';
  // Trim body to ~320 chars on a sentence boundary so the card stays a preview
  let preview = body;
  if (preview.length > 340) {
    const cut = preview.slice(0, 340);
    const lastPeriod = Math.max(cut.lastIndexOf('. '), cut.lastIndexOf('; '));
    preview = (lastPeriod > 200 ? cut.slice(0, lastPeriod + 1) : cut) + '…';
  }
  return greeting + ' ' + preview;
})();

// Featured letters
const featuredNumbers = [77, 48, 16, 3, 47];
const featured = featuredNumbers
  .map(n => enhancedIndex.letters.find(l => l.n === n)!)
  .filter(Boolean);

// Collections with letter samples
const collectionsWithSamples = Object.entries(enhancedIndex.collections).map(([name, data]) => {
  const samples = data.letters.slice(0, 3).map(n => {
    const l = enhancedIndex.letters.find(x => x.n === n);
    return l ? titleCase(cleanTitle(l.t)) : '';
  }).filter(Boolean);
  return { name, data, samples };
});

// Timeline
const timeline = enhancedIndex.timeline;

// All letter slugs for random letter
const allLetterSlugs = enhancedIndex.letters.map(l => `${l.n}-${createSlug(cleanTitle(l.t))}`);
const collectionNumerals = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII'];

function trimToBoundary(s: string, max: number): string {
  if (s.length <= max) return s;
  const cut = s.substring(0, max);
  const sentence = Math.max(cut.lastIndexOf('. '), cut.lastIndexOf('; '), cut.lastIndexOf('? '), cut.lastIndexOf('! '));
  if (sentence > max * 0.5) return cut.slice(0, sentence + 1);
  const clause = Math.max(cut.lastIndexOf(', '), cut.lastIndexOf(' — '), cut.lastIndexOf(' – '));
  if (clause > max * 0.5) return cut.slice(0, clause) + '…';
  const word = cut.lastIndexOf(' ');
  return (word > max * 0.6 ? cut.slice(0, word) : cut) + '…';
}

// Rotating epigraphs — Seneca's own lines, from these letters
const epigraphs = [
  { text: "While we are postponing, life speeds by.", ref: "Letter I" },
  { text: "Every new beginning comes from some other beginning's end.", ref: "Letter LXXVII" },
  { text: "It is not that we have a short time to live, but that we waste much of it.", ref: "On the Brevity of Life" },
  { text: "Nothing, to my way of thinking, is a better proof of a well-ordered mind than a man's ability to stop just where he is and pass some time in his own company.", ref: "Letter II" },
  { text: "He who is everywhere is nowhere.", ref: "Letter II" },
  { text: "We suffer more in imagination than in reality.", ref: "Letter XIII" },
  { text: "Begin at once to live, and count each separate day as a separate life.", ref: "Letter CI" },
  { text: "As is a tale, so is life: not how long it is, but how good it is, is what matters.", ref: "Letter LXXVII" },
  { text: "Associate with people who are likely to improve you.", ref: "Letter VII" },
  { text: "No man was ever wise by chance.", ref: "Letter LXXVI" },
  { text: "Throw away everything except the soul.", ref: "Letter LXXVI" },
  { text: "Time is the one loan which even a grateful recipient cannot repay.", ref: "Letter I" },
];
const initialEpigraph = epigraphs[Math.floor(Math.random() * epigraphs.length)];

// Pull-quote for the mid-page break
const pullQuote = {
  text: "Nothing is ours, except time.",
  ref: "Letter I · On Saving Time",
};
---

<Layout
  title="Seneca's Letters to Lucilius — Timeless Stoic Wisdom"
  description="Discover Seneca's 124 philosophical letters to Lucilius — on virtue, mortality, friendship, and the art of living well."
  canonical="/"
>
  <link slot="head" rel="prefetch" href="/api/enhanced-index.json" as="fetch" crossorigin="anonymous" />
  <Header currentPath="/" />

  <main>

    <!-- ═══════════════════════════════════════════ -->
    <!--  HERO — TITLE PAGE                         -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="hero">
      <div class="hero__inner">
        <figure class="hero__epigraph" id="heroEpigraph">
          <blockquote>
            <span class="hero__epigraph-mark" aria-hidden="true">“</span>
            <span class="hero__epigraph-text">{initialEpigraph.text}</span>
          </blockquote>
          <figcaption class="hero__epigraph-ref">— Seneca, <em>{initialEpigraph.ref}</em></figcaption>
        </figure>

        <h1 class="hero__title">
          <span class="hero__word">Letters</span>
          <span class="hero__word hero__word--italic">to Lucilius</span>
        </h1>

        <p class="hero__desc">
          One hundred and twenty-four philosophical letters on virtue,
          mortality, friendship, and the art of living well — written
          in the final years of a life at the very centre of Roman power.
        </p>

        <div class="hero__stats">
          <span class="hero__stat">
            <strong>{124}</strong>
            <small>Letters</small>
          </span>
          <span class="hero__dot" aria-hidden="true"></span>
          <span class="hero__stat">
            <strong>63–65 CE</strong>
            <small>Written</small>
          </span>
          <span class="hero__dot" aria-hidden="true"></span>
          <span class="hero__stat">
            <strong>{Math.round(totalWords / 1000)}k</strong>
            <small>Words</small>
          </span>
          <span class="hero__dot" aria-hidden="true"></span>
          <span class="hero__stat">
            <strong>1,044</strong>
            <small>Footnotes</small>
          </span>
        </div>

        <div class="hero__ctas">
          <a href="/letters/1-on-saving-time" class="hero__cta hero__cta--primary">
            Begin with Letter I
          </a>
          <a href="/library" class="hero__cta">
            Browse all 124
          </a>
          <button class="hero__cta hero__cta--random" id="randomLetterBtn" type="button">
            Random letter
          </button>
        </div>
      </div>

    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!--  LETTER I — OPENING PAGE                   -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="opening animate-enter">
      <div class="container">
        <div class="opening__layout">
          <div class="opening__annotation">
            <span class="opening__numeral">I</span>
            <span class="opening__label">On Saving Time</span>
            <span class="opening__meta">Letter I · 5 min</span>
          </div>
          <div class="opening__body">
            <p class="opening__text">{letterOneOpening}</p>
            <a href="/letters/1-on-saving-time" class="opening__cta">
              Continue reading
              <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!--  DISPATCH — FEATURED LETTERS               -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dispatch animate-enter">
      <div class="container">
        <header class="dispatch__head">
          <h2 class="dispatch__title">Begin Here</h2>
          <a href="/library" class="dispatch__more">All 124 letters →</a>
        </header>

        <div class="dispatch__grid">
          {featured.map((letter, i) => {
            const title = titleCase(cleanTitle(letter.t));
            const raw = letter.p.replace(/^\d+\.\s+/, '').replace(/\[\d+\]/g, '').replace(/\s+/g, ' ').trim();
            const excerpt = trimToBoundary(raw, 200);
            const hook = trimToBoundary(raw, 110);
            return (
              <a href={getLetterUrl(letter.n, letter.t)} class={`dispatch__item dispatch__item--${i === 0 ? 'lead' : 'secondary'} animate-enter`}>
                <div class="dispatch__item-header">
                  <span class="dispatch__numeral">{toRoman(letter.n)}</span>
                  <span class="dispatch__time">{readingTime(letter.meta.wordCount)}</span>
                </div>
                <h3 class="dispatch__item-title">{title}</h3>
                <p class="dispatch__item-theme">{letter.th}</p>
                {i === 0 && <p class="dispatch__item-excerpt">{excerpt}</p>}
                {i !== 0 && <p class="dispatch__item-hook">{hook}</p>}
                {i === 0 && <span class="dispatch__item-read" aria-hidden="true">Read this letter →</span>}
                {i !== 0 && (
                  <span class="dispatch__item-arrow" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11L11 3M11 3H5M11 3v6"/></svg>
                  </span>
                )}
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!--  PULL QUOTE                                -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="pullquote animate-enter" aria-label="Featured quote">
      <div class="container">
        <figure class="pullquote__figure">
          <span class="pullquote__mark" aria-hidden="true">“</span>
          <blockquote class="pullquote__text">{pullQuote.text}</blockquote>
          <figcaption class="pullquote__ref">{pullQuote.ref}</figcaption>
        </figure>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!--  READING PATHS                             -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="paths animate-enter">
      <div class="container">
        <header class="paths__head">
          <div>
            <h2 class="paths__title">Reading Paths</h2>
            <p class="paths__sub">Eight curated sequences through the correspondence — pick the one that meets you where you are.</p>
          </div>
        </header>

        <div class="paths__grid">
          {collectionsWithSamples.map(({ name, data, samples }, idx) => (
            <a
              href={`/library?collection=${encodeURIComponent(name)}`}
              class="path-card animate-enter"
            >
              <div class="path-card__header">
                <span class="path-card__num">{collectionNumerals[idx] ?? String(idx + 1)}</span>
                <span class="path-card__count">{data.letters.length} letters</span>
              </div>
              <div class="path-card__name">{name}</div>
              <p class="path-card__desc">{data.description}</p>
              {samples.length > 0 && (
                <div class="path-card__samples">
                  {samples.map(s => (
                    <span class="path-card__sample">{s}</span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!--  TIMELINE                                  -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="timeline-section animate-enter">
      <div class="container">
        <header class="timeline__head">
          <h2 class="timeline__title">When They Were Written</h2>
          <span class="timeline__range">63 — 65 CE · The final years</span>
        </header>

        <div class="timeline">
          {timeline.map((period, i) => (
            <a
              href={`/library?period=${encodeURIComponent(period.season)}`}
              class="timeline__seg"
              style={`flex-grow: ${period.letters.length}`}
            >
              <div class="timeline__seg-inner">
                <span class="timeline__seg-year">{period.year}</span>
                <span class="timeline__seg-season">{period.season}</span>
              </div>
              <span class="timeline__seg-count">{period.letters.length}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script is:inline define:vars={{ allLetterSlugs, epigraphs }}>
  document.getElementById('randomLetterBtn')?.addEventListener('click', function() {
    var slugs = allLetterSlugs;
    var slug = slugs[Math.floor(Math.random() * slugs.length)];
    window.location.href = '/letters/' + slug;
  });

  // Rotating epigraphs — Seneca's own voice, fresh on each visit
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var el = document.getElementById('heroEpigraph');
    if (!el) return;
    var textEl = el.querySelector('.hero__epigraph-text');
    var refEl  = el.querySelector('.hero__epigraph-ref');
    if (!textEl || !refEl) return;

    var pool = epigraphs.slice();
    var current = 0;
    for (var i = 0; i < pool.length; i++) {
      if (pool[i].text === textEl.textContent.trim()) { current = i; break; }
    }

    function swap() {
      var next = (current + 1 + Math.floor(Math.random() * (pool.length - 1))) % pool.length;
      if (next === current) next = (next + 1) % pool.length;
      el.classList.add('is-swapping');
      setTimeout(function() {
        var item = pool[next];
        textEl.textContent = item.text;
        while (refEl.firstChild) refEl.removeChild(refEl.firstChild);
        refEl.appendChild(document.createTextNode('— Seneca, '));
        var em = document.createElement('em');
        em.textContent = item.ref;
        refEl.appendChild(em);
        el.classList.remove('is-swapping');
        current = next;
      }, 600);
    }

    setInterval(swap, 9000);
  })();
</script>

<style>

  /* ═══════════════════════════════════════════════ */
  /*  HERO — TITLE PAGE                             */
  /* ═══════════════════════════════════════════════ */

  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-20) var(--space-8);
    position: relative;
    text-align: center;
    background: var(--bg-primary);
    overflow: hidden;
  }

  /* Breathing glow */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 800px 500px at 50% 45%, rgba(196,120,42,0.05), transparent 70%);
    animation: heroGlow 9s ease-in-out infinite;
    pointer-events: none;
  }

  :global([data-theme="dark"]) .hero::before {
    background: radial-gradient(ellipse 800px 500px at 50% 45%, rgba(212,146,74,0.065), transparent 70%);
  }

  @keyframes heroGlow {
    0%, 100% { opacity: 0.75; transform: scale(1); }
    50%      { opacity: 1;    transform: scale(1.06); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero::before { animation: none; }
  }

  .hero__inner {
    max-width: 720px;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  /* Rotating epigraph — Seneca's own voice */
  .hero__epigraph {
    max-width: 560px;
    margin: 0 auto var(--space-6);
    position: relative;
    transition: opacity 0.6s ease;
  }

  .hero__epigraph.is-swapping { opacity: 0; }

  .hero__epigraph blockquote {
    font-family: var(--font-display);
    font-size: clamp(1.0625rem, 1.5vw, 1.25rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.55;
    color: var(--text-secondary);
    letter-spacing: 0.005em;
    position: relative;
    padding: 0 var(--space-5);
  }

  .hero__epigraph-mark {
    position: absolute;
    top: -0.35em;
    left: -0.05em;
    font-family: var(--font-display);
    font-size: 3.25em;
    line-height: 1;
    color: var(--color-accent);
    opacity: 0.45;
    font-style: normal;
    user-select: none;
  }

  .hero__epigraph-text {
    position: relative;
  }

  .hero__epigraph-ref {
    margin-top: var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .hero__epigraph-ref em {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.05em;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--text-secondary);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 13vw, 9.5rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: var(--space-8);
  }

  .hero__word {
    display: block;
  }

  .hero__word--italic {
    font-style: italic;
    color: var(--text-secondary);
  }

  .hero__desc {
    font-family: var(--font-serif);
    font-size: clamp(0.9375rem, 1.5vw, 1.0625rem);
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 480px;
    margin: 0 auto var(--space-10);
  }

  /* Stat bar */
  .hero__stats {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .hero__stat strong {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .hero__stat:first-child strong {
    font-size: 2.5rem;
    font-style: italic;
    color: var(--color-accent);
    letter-spacing: -0.025em;
  }

  .hero__stat small {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-style: normal;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .hero__dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--border-primary);
    flex-shrink: 0;
    margin-bottom: 10px;
    align-self: flex-end;
  }

  /* CTAs */
  .hero__ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .hero__cta--primary + .hero__cta-sep {
    display: none;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    background: transparent;
    border: 1px solid var(--border-primary);
    border-radius: 2px;
    padding: 10px 20px;
    cursor: pointer;
    transition: color var(--duration-fast) ease,
                border-color var(--duration-fast) ease,
                background var(--duration-fast) ease;
  }

  .hero__cta:hover {
    color: var(--text-primary);
    border-color: var(--text-secondary);
  }

  .hero__cta--primary {
    color: var(--color-accent);
    border-color: var(--color-accent);
    font-weight: 600;
  }

  .hero__cta--primary:hover {
    background: var(--color-accent);
    color: var(--stone-50);
    border-color: var(--color-accent);
  }

  :global([data-theme="dark"]) .hero__cta--primary:hover {
    color: var(--stone-950);
  }

  .hero__cta--random::before {
    content: '';
    display: inline-block;
    width: 12px;
    height: 12px;
    border: 1px solid currentColor;
    border-radius: 2px;
    opacity: 0.55;
    background:
      radial-gradient(circle, currentColor 0 1.2px, transparent 1.6px) 3px 3px / 6px 6px no-repeat,
      radial-gradient(circle, currentColor 0 1.2px, transparent 1.6px) 6px 6px / 6px 6px no-repeat;
  }

  .hero__cta--random:hover::before {
    opacity: 1;
  }

  .hero__cta--random {
    cursor: pointer;
  }

  .hero__cta-sep {
    color: var(--border-primary);
    font-size: var(--text-lg);
    line-height: 1;
  }

  /* ═══════════════════════════════════════════════ */
  /*  LETTER I OPENING                              */
  /* ═══════════════════════════════════════════════ */

  .opening {
    padding: var(--space-24) 0;
    background: var(--bg-secondary);
  }

  .opening__layout {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-10);
    align-items: start;
    max-width: 960px;
    margin: 0 auto;
  }

  .opening__annotation {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-2);
    text-align: right;
    border-right: 1px solid var(--border-primary);
    padding-right: var(--space-10);
  }

  .opening__numeral {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 3rem;
    font-weight: 300;
    color: var(--color-accent);
    line-height: 0.95;
    letter-spacing: -0.02em;
  }

  .opening__label {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-style: italic;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.2;
  }

  .opening__meta {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin-top: var(--space-2);
  }

  .opening__body {
    min-width: 0;
  }

  .opening__text {
    font-family: var(--font-serif);
    font-size: 1.1875rem;
    line-height: 1.85;
    color: var(--text-primary);
    margin-bottom: var(--space-8);
    /* Drop cap */
    &::first-letter {
      float: left;
      font-family: var(--font-display);
      font-size: 4.5em;
      line-height: 0.78;
      font-weight: 300;
      color: var(--color-accent);
      padding-right: 0.06em;
      margin-top: 0.04em;
    }
  }

  .opening__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap var(--duration-normal) ease;
  }

  .opening__cta:hover {
    gap: 10px;
  }


  /* ═══════════════════════════════════════════════ */
  /*  DISPATCH — FEATURED                           */
  /* ═══════════════════════════════════════════════ */

  .dispatch {
