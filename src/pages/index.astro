---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import lettersData from '../data/all_letters.json';
import enhancedIndexRaw from '../../public/enhanced-index.json';
import { createSlug, cleanTitle, titleCase, getLetterUrl, readingTime, toRoman } from '../utils/text';

const enhancedIndex = enhancedIndexRaw as {
  letters: Array<{
    n: number; t: string; p: string; th: string;
    k: string[]; meta: { length: string; difficulty: string; wordCount: number };
    collections: string[]; timeline: { year: string; season: string } | null;
  }>;
  collections: Record<string, { letters: number[]; description: string; difficulty: string }>;
  timeline: Array<{ year: string; season: string; letters: number[] }>;
};

// Stats
const totalWords = enhancedIndex.letters.reduce((s, l) => s + l.meta.wordCount, 0);

// Letter I preview
const letterOne = lettersData.letters.find(l => l.number === 1);
const letterOneOpening = letterOne?.content
  .split('\n\n')[0]
  .replace(/^1\.\s+/, '')
  .replace(/\[\d+\]/g, '')
  .replace(/\n/g, ' ')
  .trim() ?? '';

// Featured letters
const featuredNumbers = [77, 48, 16, 3, 47];
const featured = featuredNumbers
  .map(n => enhancedIndex.letters.find(l => l.n === n)!)
  .filter(Boolean);

// Collections with letter samples
const collectionsWithSamples = Object.entries(enhancedIndex.collections).map(([name, data]) => {
  const samples = data.letters.slice(0, 3).map(n => {
    const l = enhancedIndex.letters.find(x => x.n === n);
    return l ? titleCase(cleanTitle(l.t)) : '';
  }).filter(Boolean);
  return { name, data, samples };
});

// Timeline
const timeline = enhancedIndex.timeline;

// All letter slugs for random letter
const allLetterSlugs = enhancedIndex.letters.map(l => `${l.n}-${createSlug(cleanTitle(l.t))}`);
const collectionNumerals = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII'];
---

<Layout
  title="Seneca's Letters to Lucilius — Timeless Stoic Wisdom"
  description="Discover Seneca's 124 philosophical letters to Lucilius — on virtue, mortality, friendship, and the art of living well."
  canonical="/"
>
  <Header currentPath="/" />

  <main>

    <!-- ═══════════════════════════════════════════ -->
    <!--  HERO — TITLE PAGE                         -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="hero">
      <div class="hero__inner">
        <p class="hero__eyebrow">Lucius Annaeus Seneca · 4 BCE – 65 CE</p>

        <h1 class="hero__title">
          <span class="hero__word">Letters</span>
          <span class="hero__word hero__word--italic">to Lucilius</span>
        </h1>

        <p class="hero__desc">
          One hundred and twenty-four philosophical letters on virtue,
          mortality, friendship, and the art of living well — written
          in the final years of a life at the very centre of Roman power.
        </p>

        <div class="hero__stats">
          <span class="hero__stat">
            <strong>{124}</strong>
            <small>Letters</small>
          </span>
          <span class="hero__dot" aria-hidden="true"></span>
          <span class="hero__stat">
            <strong>63–65 CE</strong>
            <small>Written</small>
          </span>
          <span class="hero__dot" aria-hidden="true"></span>
          <span class="hero__stat">
            <strong>{Math.round(totalWords / 1000)}k</strong>
            <small>Words</small>
          </span>
          <span class="hero__dot" aria-hidden="true"></span>
          <span class="hero__stat">
            <strong>1,044</strong>
            <small>Footnotes</small>
          </span>
        </div>

        <div class="hero__ctas">
          <a href="/letters/1-on-saving-time" class="hero__cta hero__cta--primary">
            Begin with Letter I
          </a>
          <span class="hero__cta-sep" aria-hidden="true">·</span>
          <a href="/library" class="hero__cta">
            Browse all 124
          </a>
          <span class="hero__cta-sep" aria-hidden="true">·</span>
          <button class="hero__cta hero__cta--random" id="randomLetterBtn" type="button">
            Random letter
          </button>
        </div>
      </div>

    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!--  LETTER I — OPENING PAGE                   -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="opening">
      <div class="container">
        <div class="opening__layout">
          <div class="opening__annotation">
            <span class="opening__numeral">I</span>
            <span class="opening__label">On Saving Time</span>
            <span class="opening__meta">Letter I · 5 min</span>
          </div>
          <div class="opening__body">
            <p class="opening__text">{letterOneOpening}</p>
            <a href="/letters/1-on-saving-time" class="opening__cta">
              Continue reading
              <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!--  DISPATCH — FEATURED LETTERS               -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="dispatch">
      <div class="container">
        <header class="dispatch__head">
          <h2 class="dispatch__title">Begin Here</h2>
          <a href="/library" class="dispatch__more">All 124 letters →</a>
        </header>

        <div class="dispatch__grid">
          {featured.map((letter, i) => {
            const title = titleCase(cleanTitle(letter.t));
            const excerpt = letter.p.replace(/^\d+\.\s+/, '').replace(/\[\d+\]/g, '').substring(0, 140).trim();
            return (
              <a href={getLetterUrl(letter.n, letter.t)} class={`dispatch__item dispatch__item--${i === 0 ? 'lead' : 'secondary'}`}>
                <div class="dispatch__item-header">
                  <span class="dispatch__numeral">{toRoman(letter.n)}</span>
                  <span class="dispatch__time">{readingTime(letter.meta.wordCount)}</span>
                </div>
                <h3 class="dispatch__item-title">{title}</h3>
                <p class="dispatch__item-theme">{letter.th}</p>
                {i === 0 && <p class="dispatch__item-excerpt">{excerpt}…</p>}
                {i === 0 && <span class="dispatch__item-read" aria-hidden="true">Read this letter →</span>}
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!--  READING PATHS                             -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="paths">
      <div class="container">
        <header class="paths__head">
          <h2 class="paths__title">Reading Paths</h2>
        </header>

        <div class="paths__grid">
          {collectionsWithSamples.map(({ name, data, samples }, idx) => (
            <a
              href={`/library?collection=${encodeURIComponent(name)}`}
              class="path-card"
            >
              <div class="path-card__header">
                <span class="path-card__num">{collectionNumerals[idx] ?? String(idx + 1)}</span>
                <span class="path-card__count">{data.letters.length} letters</span>
              </div>
              <div class="path-card__name">{name}</div>
              <p class="path-card__desc">{data.description}</p>
              {samples.length > 0 && (
                <div class="path-card__samples">
                  {samples.map(s => (
                    <span class="path-card__sample">{s}</span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════ -->
    <!--  TIMELINE                                  -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="timeline-section">
      <div class="container">
        <header class="timeline__head">
          <h2 class="timeline__title">When They Were Written</h2>
        </header>

        <div class="timeline">
          {timeline.map((period, i) => (
            <a
              href={`/library?period=${encodeURIComponent(period.season)}`}
              class="timeline__seg"
              style={`flex-grow: ${period.letters.length}`}
            >
              <div class="timeline__seg-inner">
                <span class="timeline__seg-year">{period.year}</span>
                <span class="timeline__seg-season">{period.season}</span>
              </div>
              <span class="timeline__seg-count">{period.letters.length}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script is:inline define:vars={{ allLetterSlugs }}>
  document.getElementById('randomLetterBtn')?.addEventListener('click', function() {
    var slugs = allLetterSlugs;
    var slug = slugs[Math.floor(Math.random() * slugs.length)];
    window.location.href = '/letters/' + slug;
  });
</script>

<style>

  /* ═══════════════════════════════════════════════ */
  /*  HERO — TITLE PAGE                             */
  /* ═══════════════════════════════════════════════ */

  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-20) var(--space-8);
    position: relative;
    text-align: center;
  }

  .hero__inner {
    max-width: 720px;
    width: 100%;
  }

  .hero__eyebrow {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-muted);
    margin-bottom: var(--space-8);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 13vw, 9.5rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: var(--space-8);
  }

  .hero__word {
    display: block;
  }

  .hero__word--italic {
    font-style: italic;
    color: var(--text-secondary);
  }

  .hero__desc {
    font-family: var(--font-serif);
    font-size: clamp(0.9375rem, 1.5vw, 1.0625rem);
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 480px;
    margin: 0 auto var(--space-10);
  }

  /* Stat bar */
  .hero__stats {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .hero__stat strong {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .hero__stat small {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-style: normal;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .hero__dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--border-primary);
    flex-shrink: 0;
    margin-bottom: 10px;
    align-self: flex-end;
  }

  /* CTAs */
  .hero__ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
  }

  .hero__cta {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    background: none;
    border: none;
    padding: 0;
    transition: color var(--duration-fast) ease;
  }

  .hero__cta--primary {
    color: var(--color-accent);
    border-bottom: 1px solid var(--color-accent);
    padding-bottom: 2px;
  }

  .hero__cta:hover {
    color: var(--text-primary);
  }

  .hero__cta--primary:hover {
    color: var(--color-accent);
    border-bottom-color: transparent;
  }

  .hero__cta--random {
    cursor: pointer;
  }

  .hero__cta-sep {
    color: var(--border-primary);
    font-size: var(--text-lg);
    line-height: 1;
  }

  /* ═══════════════════════════════════════════════ */
  /*  LETTER I OPENING                              */
  /* ═══════════════════════════════════════════════ */

  .opening {
    padding: var(--space-24) 0;
    background: var(--bg-secondary);
  }

  .opening__layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-12);
    align-items: start;
    max-width: 900px;
  }

  .opening__annotation {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-2);
    text-align: right;
    border-right: 1px solid var(--border-primary);
    padding-right: var(--space-10);
  }

  .opening__numeral {
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 300;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .opening__label {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-style: italic;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.2;
  }

  .opening__meta {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin-top: var(--space-2);
  }

  .opening__body {
    min-width: 0;
  }

  .opening__text {
    font-family: var(--font-serif);
    font-size: 1.1875rem;
    line-height: 1.85;
    color: var(--text-primary);
    margin-bottom: var(--space-8);
    /* Drop cap */
    &::first-letter {
      float: left;
      font-family: var(--font-display);
      font-size: 4.5em;
      line-height: 0.78;
      font-weight: 300;
      color: var(--color-accent);
      padding-right: 0.06em;
      margin-top: 0.04em;
    }
  }

  .opening__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap var(--duration-normal) ease;
  }

  .opening__cta:hover {
    gap: 10px;
  }


  /* ═══════════════════════════════════════════════ */
  /*  DISPATCH — FEATURED                           */
  /* ═══════════════════════════════════════════════ */

  .dispatch {
    padding: var(--space-24) 0;
  }

  .dispatch__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-10);
  }

  .dispatch__title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-style: italic;
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: -0.015em;
  }

  .dispatch__title::before {
    content: '';
    display: block;
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .dispatch__more {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .dispatch__more:hover {
    color: var(--color-accent);
  }

  /* Two-column magazine grid: lead + 4 secondary */
  .dispatch__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1px;
    background: var(--border-light);
  }

  .dispatch__item {
    background: var(--bg-primary);
    padding: var(--space-8);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition: background var(--duration-normal) ease;
  }

  .dispatch__item:hover {
    background: var(--color-accent-subtle);
    box-shadow: 0 1px 6px rgba(0,0,0,0.03);
  }

  /* Lead item spans full left column */
  .dispatch__item--lead {
    grid-row: 1 / 3;
    padding: var(--space-12);
    border-left: 2px solid var(--color-accent);
  }

  .dispatch__item-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }

  .dispatch__numeral {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1;
    letter-spacing: 0.02em;
    transition: color var(--duration-fast) ease;
  }

  .dispatch__item:hover .dispatch__numeral {
    color: var(--color-accent);
  }

  .dispatch__item--lead .dispatch__numeral {
    font-size: 3.5rem;
    color: var(--color-accent);
  }

  .dispatch__time {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .dispatch__item-title {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 400;
    color: var(--text-primary);
    line-height: 1.3;
    transition: color var(--duration-fast) ease;
  }

  .dispatch__item--lead .dispatch__item-title {
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 400;
    letter-spacing: -0.015em;
    margin-bottom: var(--space-1);
  }

  .dispatch__item-theme {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    letter-spacing: 0.01em;
  }

  .dispatch__item-excerpt {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-top: var(--space-3);
    max-width: 520px;
  }

  .dispatch__item-read {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-top: auto;
    padding-top: var(--space-5);
  }

  .dispatch__item--secondary .dispatch__item-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: -0.01em;
  }


  /* ═══════════════════════════════════════════════ */
  /*  READING PATHS                                 */
  /* ═══════════════════════════════════════════════ */

  .paths {
    padding: var(--space-24) 0;
    background: var(--color-accent-subtle);
  }

  .paths__head {
    margin-bottom: var(--space-10);
    display: flex;
    align-items: baseline;
    gap: var(--space-5);
  }

  .paths__title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-style: italic;
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: -0.015em;
  }

  .paths__title::before {
    content: '';
    display: block;
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .paths__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: transparent;
    max-width: 900px;
  }

  .path-card {
    background: var(--bg-primary);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: box-shadow var(--duration-normal) ease, border-color var(--duration-normal) ease;
  }

  .path-card:hover {
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    border-left-color: var(--color-accent);
  }

  .path-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .path-card__num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-accent);
    letter-spacing: 0.08em;
  }

  .path-card__count {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .path-card__name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    line-height: 1.2;
    transition: color var(--duration-fast) ease;
  }

  .path-card:hover .path-card__name {
    color: var(--color-accent);
  }

  .path-card__desc {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: 1.5;
    letter-spacing: 0.01em;
  }

  .path-card__samples {
    border-top: 1px solid var(--border-light);
    padding-top: var(--space-3);
    margin-top: auto;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
  }

  .path-card__sample {
    display: inline;
  }

  .path-card__sample:not(:last-child)::after {
    content: ', ';
    font-style: normal;
  }


  /* ═══════════════════════════════════════════════ */
  /*  TIMELINE                                      */
  /* ═══════════════════════════════════════════════ */

  .timeline-section {
    padding: var(--space-24) 0;
  }

  .timeline__head {
    display: flex;
    align-items: baseline;
    gap: var(--space-5);
    margin-bottom: var(--space-10);
  }

  .timeline__title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-style: italic;
    font-weight: 400;
    color: var(--text-primary);
    letter-spacing: -0.015em;
  }

  .timeline__title::before {
    content: '';
    display: block;
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .timeline {
    display: flex;
    max-width: 900px;
  }

  .timeline__seg {
    flex: 1;
    min-height: 150px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-decoration: none;
    padding: var(--space-6) var(--space-5);
    border-top: 2px solid var(--border-light);
    position: relative;
    transition: border-color var(--duration-normal) ease, background var(--duration-normal) ease;
  }

  .timeline__seg + .timeline__seg {
    border-left: 1px solid var(--border-light);
  }

