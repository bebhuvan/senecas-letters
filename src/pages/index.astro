---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import LetterCard from '../components/LetterCard.astro';
import '../styles/global.css';

const letters = await getCollection('letters');

// Manually curated most essential letters based on philosophical impact
const essentialLetterNumbers = [1, 7, 12, 77, 47, 18];
const featured = essentialLetterNumbers
  .map(num => letters.find(l => l.data.number === num))
  .filter(Boolean);

const recent = letters.slice(0, 4);
---

<BaseLayout 
  title="Seneca's Letters to Lucilius"
  description="124 letters from the Roman philosopher Seneca to his younger friend Lucilius. Timeless wisdom on how to live well."
>
  <Navigation />
  
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-label">124 Letters · 3 Years · One Friendship</div>
        
        <h1 class="hero-title text-balance">
          Seneca's Letters to <span class="accent">Lucilius</span>
        </h1>
        
        <div class="hero-description">
          <p>
            In the twilight of his life, the Roman philosopher Seneca penned 124 letters to his younger friend Lucilius. What began as personal correspondence became one of history's most profound explorations of how to live well.
          </p>
          <p>
            These letters are not abstract philosophy but practical wisdom — intimate, conversational, and startlingly relevant. They teach us to value time above gold, find freedom through discipline, and seek tranquility not in circumstances but in the cultivation of our minds.
          </p>
        </div>
        
        <p class="hero-intro text-balance">
          "What man can you show me who places any value on his time, who reckons the worth of each day, who understands that he is dying daily? For we are mistaken when we look forward to death; the major portion of death has already passed. Whatever years lie behind us are in death's hands."
        </p>
        
        <div class="quote-attribution">
          — <a href="/letters/letter-001" class="attribution-link">Letter 1: On Saving Time</a>
        </div>
        
        <div class="hero-meta">
          <span class="meta-left">4 BCE — 65 CE · Stoic Philosopher · Advisor to Emperors</span>
          <a href="/letters/letter-001" class="btn btn-primary">Begin Reading</a>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Navigation Links -->
  <section class="nav-links-section">
    <div class="nav-links-container">
      <a href="/letters/letter-001" class="nav-link-item">
        <span class="nav-link-label">Start Reading</span>
        <span class="nav-link-desc">Letter 1: On Saving Time</span>
      </a>
      <a href="/archive" class="nav-link-item">
        <span class="nav-link-label">Browse Archive</span>
        <span class="nav-link-desc">All 124 Letters</span>
      </a>
      <a href="/search" class="nav-link-item">
        <span class="nav-link-label">Search</span>
        <span class="nav-link-desc">Find by Topic</span>
      </a>
      <a href="/about" class="nav-link-item">
        <span class="nav-link-label">About</span>
        <span class="nav-link-desc">The Collection</span>
      </a>
    </div>
  </section>
  
  <!-- Featured Letters -->
  <section class="featured-section section">
    <div class="section-header">
      <div class="section-label">Start Here</div>
      <h2 class="section-title">Essential Letters</h2>
      <p class="section-description">
        Begin your journey with six of the most transformative letters. Each explores profound questions about how to live well — from the nature of time to finding peace in uncertainty.
      </p>
    </div>
    
    <div class="letters-showcase container">
      <!-- Left Column: 2 Hero Letters -->
      <div class="hero-letters">
        {featured.slice(0, 2).map((letter, index) => (
          <a href={`/letters/${letter.slug}`} class="hero-letter-card">
            {index === 0 && (
              <div class="letter-badge">Most Read</div>
            )}
            <div class="hero-letter-number">Letter {letter.data.number}</div>
            <h3 class="hero-letter-title">{letter.data.title}</h3>
            <p class="hero-letter-excerpt">{letter.data.excerpt.substring(0, 280)}...</p>
            <div class="hero-letter-meta">
              <span class="theme-tag">{letter.data.themes[0]}</span>
              <span class="reading-time">{letter.data.readingTime} min</span>
            </div>
          </a>
        ))}
      </div>
      
      <!-- Right Column: 4 Supporting Letters -->
      <div class="supporting-letters">
        {featured.slice(2, 6).map((letter) => (
          <a href={`/letters/${letter.slug}`} class="supporting-letter-card">
            <div class="supporting-letter-number">Letter {letter.data.number}</div>
            <h4 class="supporting-letter-title">{letter.data.title}</h4>
            <p class="supporting-letter-excerpt">{letter.data.excerpt.substring(0, 140)}...</p>
            <div class="supporting-letter-meta">
              <span class="theme-tag">{letter.data.themes[0]}</span>
              <span class="reading-time">{letter.data.readingTime} min</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Recent Letters -->
  <section class="recent-section section">
    <div class="section-header">
      <div class="section-label">Complete Collection</div>
      <h2 class="section-title">All Letters</h2>
      <p class="section-description">
        The complete correspondence, in chronological order
      </p>
    </div>
    
    <div class="letters-list content-container">
      {recent.map((letter) => (
        <a href={`/letters/${letter.slug}`} class="letter-item">
          <div class="item-header">
            <span class="item-number">Letter {letter.data.number}</span>
            <span class="item-date">{letter.data.date}</span>
          </div>
          <h3 class="item-title">{letter.data.title}</h3>
          <p class="item-excerpt">{letter.data.excerpt}</p>
        </a>
      ))}
      
      <div class="view-all">
        <a href="/archive" class="btn btn-secondary">View All Letters</a>
      </div>
    </div>
  </section>
  
  <!-- CTA Section -->
  <section class="cta-section section">
    <div class="cta-content">
      <h2 class="cta-title">Begin Your Journey</h2>
      <p class="cta-text">
        2,000 years later, Seneca's wisdom remains startlingly relevant. 
        Start with Letter I, or explore the complete archive.
      </p>
      <div class="cta-buttons">
        <a href="/letters/letter-001" class="btn btn-primary">Start with Letter I</a>
        <a href="/archive" class="btn btn-secondary">Browse Archive</a>
      </div>
    </div>
  </section>
  
  <!-- Footer -->
  <footer>
    <div class="footer-content">
      <div>© Letters to Lucilius · Timeless Wisdom</div>
      <div class="footer-links">
        <a href="/about">About</a>
        <a href="/archive">Archive</a>
        <a href="/search">Search</a>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    margin-top: 3.5rem;
    padding: 7rem 2rem 6rem;
    background: var(--bg-soft);
    min-height: 90vh;
    display: flex;
    align-items: center;
  }
  
  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  
  .hero-content {
    max-width: var(--content-width);
  }
  
  .hero-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--royal-blue);
    margin-bottom: 2rem;
  }
  
  .hero-title {
    font-size: var(--text-5xl);
    font-weight: 300;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin-bottom: 2.5rem;
  }
  
  .hero-title .accent {
    color: var(--royal-blue);
    font-style: italic;
    font-weight: 400;
  }
  
  .hero-intro {
    font-size: var(--text-xl);
    font-weight: 300;
    font-style: italic;
    color: var(--text-primary);
    line-height: 1.5;
    margin: 2.5rem 0 1.5rem -2.5rem;
    padding: 2rem 0 2rem 2.5rem;
    background: var(--bg-soft);
    border-left: 3px solid rgba(37, 99, 235, 0.3);
    position: relative;
    letter-spacing: 0;
    border-radius: 0 4px 4px 0;
  }
  
  .hero-intro::before {
    content: '"';
    position: absolute;
    top: 1rem;
    left: 1.5rem;
    font-size: 3rem;
    font-family: var(--font-serif);
    color: var(--royal-blue);
    opacity: 0.2;
    line-height: 1;
  }
  
  .quote-attribution {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-tertiary);
    margin-bottom: 3.5rem;
    text-align: right;
    margin-top: -1rem;
    padding-right: 1rem;
  }
  
  .attribution-link {
    color: var(--royal-blue);
    text-decoration: none;
  }
  
  .hero-description {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    letter-spacing: var(--tracking-normal);
  }
  
  .hero-description p {
    margin-bottom: 2.25rem;
  }
  
  .hero-meta {
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border-light);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .meta-left {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-tertiary);
    letter-spacing: var(--tracking-wider);
    line-height: var(--leading-relaxed);
  }
  
  /* Navigation Links */
  .nav-links-section {
    padding: 4rem 2rem;
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-light);
  }
  
  .nav-links-container {
    max-width: var(--content-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  
  .nav-link-item {
    text-decoration: none;
    color: inherit;
    padding: 1.5rem 0;
    text-align: center;
    display: block;
  }
  
  .nav-link-label {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--royal-blue);
    display: block;
    margin-bottom: 0.5rem;
  }
  
  .nav-link-desc {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    font-weight: 500;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }
  
  /* Featured Section */
  .featured-section {
    background: var(--bg-soft);
  }
  
  .letters-showcase {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: stretch;
    min-height: 100%;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .hero-letters {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    height: 100%;
  }
  
  .hero-letter-card {
    padding: 3rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    position: relative;
    flex: 1;
  }
  
  .hero-letter-number {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--royal-blue);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: 1.25rem;
  }
  
  .hero-letter-title {
    font-size: var(--text-2xl);
    font-weight: 400;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
    line-height: var(--leading-tight);
  }
  
  .hero-letter-excerpt {
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin-bottom: auto;
    flex-grow: 1;
  }
  
  .hero-letter-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-light);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
  }
  
  /* Hero Letter */
  .hero-letter {
    position: relative;
  }
  
  .hero-letter-card {
    display: flex;
    flex-direction: column;
    padding: 2.5rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    text-decoration: none;
    color: inherit;
    position: relative;
    height: 100%;
  }
  
  .hero-letter-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: var(--text-tertiary);
    color: white;
    padding: 0.25rem 0.75rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }
  
  .hero-letter-number {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--royal-blue);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: 1.5rem;
  }
  
  .hero-letter-title {
    font-size: var(--text-2xl);
    font-weight: 400;
    line-height: var(--leading-tight);
    margin-bottom: 1.5rem;
    letter-spacing: var(--tracking-tight);
  }
  
  .hero-letter-excerpt {
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    flex-grow: 1;
    margin-bottom: 1.5rem;
  }
  
  .hero-letter-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    border-top: 1px solid var(--border-light);
    padding-top: 1.5rem;
    margin-top: auto;
  }
  
  /* Supporting Letters */
  .supporting-letters {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .supporting-letter-card {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    text-decoration: none;
    color: inherit;
    position: relative;
  }
  
  .supporting-letter-number {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--royal-blue);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: 0.75rem;
  }
  
  .supporting-letter-title {
    font-size: var(--text-lg);
    font-weight: 400;
    line-height: var(--leading-snug);
    margin-bottom: 1rem;
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
  }
  
  .supporting-letter-excerpt {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: auto;
    flex-grow: 1;
  }
  
  .supporting-letter-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-light);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
  }
  
  .theme-tag {
    color: var(--royal-blue);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: capitalize;
    letter-spacing: var(--tracking-wide);
    padding: 0.125rem 0.5rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-radius: 4px;
  }
  
  .reading-time {
    color: var(--text-tertiary);
    font-weight: 500;
  }
  
  /* Recent Section */
  .recent-section {
    background: var(--bg-primary);
  }
  
  .letters-list {
    max-width: var(--content-width);
    margin: 0 auto;
  }
  
  .letter-item {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border-light);
    display: block;
    text-decoration: none;
    color: inherit;
    transition: color 0.2s ease;
  }
  
  .item-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
  }
  
  .item-number {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--royal-blue);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }
  
  .item-date {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: var(--tracking-wide);
  }
  
  .item-title {
    font-size: var(--text-2xl);
    font-weight: 400;
    margin-bottom: 1rem;
    color: var(--text-primary);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
  }
  
  .item-excerpt {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    letter-spacing: var(--tracking-normal);
  }
  
  .view-all {
    margin-top: 3rem;
    text-align: center;
  }
  
  /* CTA Section */
  .cta-section {
    text-align: center;
    border-top: 1px solid var(--border-light);
    background: var(--bg-soft);
  }
  
  .cta-content {
    max-width: 640px;
    margin: 0 auto;
  }
  
  .cta-title {
    font-size: var(--text-3xl);
    font-weight: 300;
    margin-bottom: 1.5rem;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
  }
  
  .cta-text {
    font-size: var(--text-md);
    color: var(--text-secondary);
    margin-bottom: 3rem;
    line-height: var(--leading-relaxed);
    letter-spacing: var(--tracking-normal);
  }
  
  .cta-buttons {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
  }
  
  /* Footer */
  footer {
    padding: 3.5rem 2rem;
    background: var(--bg-primary);
    border-top: 1px solid var(--border-light);
  }
  
  .footer-content {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    letter-spacing: var(--tracking-wide);
  }
  
  .footer-links {
    display: flex;
    gap: 2.5rem;
  }
  
  .footer-links a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  .footer-links a:hover {
    color: var(--text-primary);
  }
  
  /* Responsive */
  @media (max-width: 1024px) {
    .letters-showcase {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .hero-letter-card {
      min-height: 300px;
    }
  }
  
  @media (max-width: 768px) {
    .hero-title {
      font-size: var(--text-4xl);
    }
    
    .hero-intro {
      font-size: var(--text-lg);
      padding: 1.5rem 0 1.5rem 2rem;
      margin: 2rem 0 1rem -2rem;
    }
    
    .hero-intro::before {
      top: 0.75rem;
      left: 1rem;
      font-size: 2.5rem;
    }
    
    .nav-links-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
    
    .cta-buttons {
      flex-direction: column;
    }
    
    .footer-content {
      flex-direction: column;
      gap: 2rem;
      text-align: center;
    }
  }
  
  @media (max-width: 480px) {
    .hero {
      padding: 5rem 1.5rem 4rem;
    }
    
    .hero-title {
      font-size: var(--text-3xl);
    }
    
    .hero-meta {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
    }
  }
  
</style>