---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found - Seneca's Letters"
  description="The page you're looking for could not be found."
>
  <Header />

  <main class="notfound">
    <div class="container">
      <div class="notfound__inner">
        <p class="notfound__code">404</p>
        <h1 class="notfound__heading">Page not found</h1>

        <blockquote class="notfound__quote">
          "We suffer more in imagination than in reality."
          <cite>— <a href="/letters/13-on-groundless-fears">Letter XIII · On Groundless Fears</a></cite>
        </blockquote>

        <div class="notfound__links">
          <a href="/">Return home</a>
          <a href="/library">Browse the library</a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .notfound {
    min-height: 70vh;
    display: flex;
    align-items: center;
  }

  .notfound__inner {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
    padding: var(--space-16) 0;
  }

  .notfound__code {
    font-family: var(--font-serif);
    font-size: var(--text-6xl);
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1;
    margin-bottom: var(--space-4);
  }

  .notfound__heading {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: var(--space-10);
  }

  .notfound__quote {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-10);
  }

  .notfound__quote cite {
    display: block;
    font-style: normal;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-top: var(--space-2);
  }

  .notfound__quote cite a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .notfound__quote cite a:hover {
    text-decoration: underline;
  }

  .notfound__links {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
  }

  .notfound__links a {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-accent);
    text-decoration: none;
  }

  .notfound__links a:hover {
    text-decoration: underline;
  }
</style>
