---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  structuredData?: any;
}

const { title, description, ogImage = '/og-image.jpg', structuredData } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Performance optimizations -->
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#5B73E8" />
    <link rel="dns-prefetch" href="//fonts.googleapis.com" />
    <link rel="dns-prefetch" href="//fonts.gstatic.com" />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Structured Data -->
    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    )}
    
    <!-- No external fonts - instant rendering with beautiful system fonts -->
    <!-- Immediate system font fallbacks for instant rendering -->
    <style>
      /* Default system fonts load instantly - no network delay */
      body { font-family: Georgia, 'Times New Roman', serif; }
      .font-sans, .header-actions, .breadcrumb, .letter-meta { 
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; 
      }
      
      /* Enhanced font options using fast system fonts */
      .font-serif { font-family: Georgia, 'Times New Roman', serif; }
      .font-georgia { font-family: Georgia, serif; }
      .font-sans { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; }
      .font-system { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; }
      .font-mono { font-family: 'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', 'Courier New', monospace; }
      
      /* Update CSS variables to use system fonts */
      :root {
        --font-serif: Georgia, 'Times New Roman', serif;
        --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      }
    </style>
    
    <!-- Theme initialization (prevent flicker) -->
    <script is:inline>
      // This runs immediately to prevent theme flicker
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      
      const theme = getThemePreference();
      document.documentElement.setAttribute('data-theme', theme);
      
      // System fonts are already loaded - no additional font loading needed
    </script>
  </head>
  <body>
    <slot />
    
    <script is:inline>
      // Theme toggle function (theme is already initialized in head)
      window.toggleTheme = function() {
        const html = document.documentElement;
        const currentTheme = html.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
      }
    </script>
  </body>
</html>