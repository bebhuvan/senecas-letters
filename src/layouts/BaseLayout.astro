---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  structuredData?: any;
}

const { title, description, ogImage = '/og-image.jpg', structuredData } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Performance optimizations -->
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#5B73E8" />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Structured Data -->
    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    )}
    
    <!-- CRITICAL CSS - Inlined for instant rendering -->
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      
      :root {
        --royal-blue: #5B73E8;
        --soft-blue: #E8F0FE;
        --text-primary: #1a1a1a;
        --text-secondary: #4a4a4a;
        --text-tertiary: #7a7a7a;
        --text-muted: #9a9a9a;
        --bg-primary: #ffffff;
        --bg-soft: #fafaf8;
        --border-light: #e5e5e0;
        --max-width: 1200px;
        --content-width: 920px;
        --font-serif: Georgia, 'Times New Roman', serif;
        --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        --text-xs: 0.694rem;
        --text-sm: 0.833rem;
        --text-base: 1rem;
        --text-md: 1.2rem;
        --text-lg: 1.44rem;
        --text-xl: 1.728rem;
        --text-2xl: 2.074rem;
        --text-3xl: 2.488rem;
        --text-4xl: 2.986rem;
        --text-5xl: 3.583rem;
        --leading-tight: 1.15;
        --leading-snug: 1.35;
        --leading-normal: 1.5;
        --leading-relaxed: 1.65;
        --leading-loose: 1.85;
        --tracking-tight: -0.03em;
        --tracking-normal: 0;
        --tracking-wide: 0.025em;
        --tracking-wider: 0.05em;
        --tracking-widest: 0.1em;
      }
      
      [data-theme="dark"] {
        --text-primary: #f0f0f0;
        --text-secondary: #c0c0c0;
        --text-tertiary: #8a8a8a;
        --text-muted: #6a6a6a;
        --bg-primary: #0a0a0a;
        --bg-soft: #0f0f0d;
        --border-light: #2a2a25;
        --soft-blue: #1a2332;
      }
      
      html {
        font-size: 19px;
        line-height: var(--leading-normal);
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        scroll-behavior: smooth;
      }
      
      body {
        font-family: var(--font-serif);
        font-weight: 400;
        color: var(--text-primary);
        background: var(--bg-primary);
        min-height: 100vh;
        transition: background 0.3s ease, color 0.3s ease;
      }
      
      ::selection {
        background: var(--soft-blue);
        color: var(--text-primary);
      }
      
      .container { max-width: var(--max-width); margin: 0 auto; padding: 0 2rem; }
      .content-container { max-width: var(--content-width); margin: 0 auto; padding: 0 2rem; }
      .section { padding: 5rem 2rem; }
      .section-header { text-align: center; margin-bottom: 4rem; }
      .section-title { font-size: var(--text-3xl); font-weight: 300; margin-bottom: 1.5rem; letter-spacing: var(--tracking-tight); }
      .section-description { font-size: var(--text-md); color: var(--text-secondary); max-width: 640px; margin: 0 auto; line-height: var(--leading-relaxed); }
      
      .btn {
        display: inline-block;
        padding: 0.875rem 2rem;
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        font-weight: 500;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: all 0.2s ease;
        letter-spacing: var(--tracking-wide);
        text-transform: uppercase;
      }
      
      .btn-primary { background: var(--royal-blue); color: white; }
      .btn-secondary { background: transparent; color: var(--text-primary); border: 1px solid var(--border-light); }
      
      .text-balance { text-wrap: balance; }
      .font-sans { font-family: var(--font-sans); }
      .font-serif { font-family: var(--font-serif); }
      
      .letter-content p {
        margin-bottom: 2.25rem;
        font-size: 1.3rem;
        line-height: 1.7;
        color: var(--text-primary);
        max-width: 75ch;
        font-family: var(--font-serif);
      }
      
      nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: var(--bg-primary);
        border-bottom: 1px solid var(--border-light);
        padding: 1rem 2rem;
      }
      
      .nav-content {
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      
      .nav-brand {
        font-family: var(--font-sans);
        font-size: var(--text-lg);
        font-weight: 600;
        color: var(--text-primary);
        text-decoration: none;
      }
      
      .nav-links {
        display: flex;
        gap: 2rem;
        list-style: none;
      }
      
      .nav-links a {
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        color: var(--text-secondary);
        text-decoration: none;
        transition: color 0.2s ease;
      }
      
      .nav-links a:hover { color: var(--text-primary); }
      
      .hero {
        margin-top: 3.5rem;
        padding: 7rem 2rem 6rem;
        background: var(--bg-soft);
        min-height: 90vh;
        display: flex;
        align-items: center;
      }
      
      .hero-inner { max-width: var(--max-width); margin: 0 auto; }
      .hero-content { max-width: var(--content-width); }
      
      .hero-title {
        font-size: var(--text-5xl);
        font-weight: 300;
        line-height: var(--leading-tight);
        letter-spacing: var(--tracking-tight);
        margin-bottom: 2.5rem;
      }
      
      .hero-title .accent {
        color: var(--royal-blue);
        font-style: italic;
        font-weight: 400;
      }
    </style>
    
    <!-- Theme initialization (prevent flicker) -->
    <script is:inline>
      const getThemePreference=()=>{
        if(typeof localStorage!=='undefined'&&localStorage.getItem('theme')){
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';
      };
      
      const theme=getThemePreference();
      document.documentElement.setAttribute('data-theme',theme);
    </script>
  </head>
  <body>
    <slot />
    
    <!-- Load non-critical CSS asynchronously -->
    <link rel="preload" href="/_astro/global.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="/_astro/global.css"></noscript>
    
    <script is:inline>
      window.toggleTheme=function(){
        const html=document.documentElement;
        const currentTheme=html.getAttribute('data-theme');
        const newTheme=currentTheme==='dark'?'light':'dark';
        html.setAttribute('data-theme',newTheme);
        localStorage.setItem('theme',newTheme);
      }
    </script>
  </body>
</html>